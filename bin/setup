#!/bin/bash

command -v rbenv >/dev/null 2>&1 && eval "$(rbenv init - bash 2>/dev/null)" || true

echo "🔧 Setting up Wedly..."
echo ""

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

echo "✓ Ruby version: $(ruby --version)"
echo ""

echo "📦 Installing dependencies..."
bundle install

if [ ! -f .env ]; then
  echo ""
  echo "📝 Creating .env file..."
  cp .env.example .env
  echo "✓ .env created (configure SMTP settings before sending emails)"
fi

echo ""
echo "🧹 Clearing logs and temp files..."
bin/rails log:clear
bin/rails tmp:clear

echo ""
echo "🗄️  Setting up database..."
bin/rails db:create
bin/rails db:migrate
bin/rails db:seed

echo ""
echo "🎨 Building CSS..."
bin/rails tailwindcss:build

echo ""
echo "✅ Setup complete!"
echo ""
echo "To start the server, run:"
echo "  ./bin/dev"
echo ""
echo "Admin login: http://localhost:3003/admin/login"
echo "  Email: admin@wedly.com"
echo "  Password: password"
