<% response_copy = ->(status) {
     case status
     when "accepted" then ["Joyfully accepts", "#A07658"]
     when "declined" then ["Regretfully declines", "#a8a29e"]
     else ["Awaiting reply", "#a8a29e"]
     end
   } %>

<div style="text-align:center;">
  <p class="sans" style="margin:0; font-family:'Montserrat',Helvetica,Arial,sans-serif; font-size:11px; font-weight:400; letter-spacing:0.28em; text-transform:uppercase; color:#C89B7B;">
    Thank you
  </p>

  <p class="mono" style="margin:16px 0 0; font-family:'Cormorant Garamond',Georgia,serif; font-size:36px; font-weight:400; line-height:1.15; color:#292524;">
    Your RSVP is confirmed
  </p>

  <p class="sans" style="margin:16px auto 0; max-width:380px; font-family:'Montserrat',Helvetica,Arial,sans-serif; font-size:15px; font-weight:300; line-height:1.9; color:#57534e;">
    We&rsquo;ve received your response &mdash; here&rsquo;s what we have on file for your party.
  </p>
</div>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0">
  <% @guests.each_with_index do |guest, index| %>
    <% label, label_color = response_copy.call(guest.rsvp_status) %>
    <tr>
      <td style="padding: 18px 0; <%= "border-top:1px solid #F0EAE3;" unless index.zero? %>">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td style="vertical-align:top;">
              <div class="mono" style="font-family:'Cormorant Garamond',Georgia,serif; font-size:21px; font-weight:500; color:#292524;">
                <%= guest.full_name %>
              </div>
              <% if guest.rsvp&.meal_choice.present? %>
                <div class="sans" style="font-family:'Montserrat',Helvetica,Arial,sans-serif; font-size:11px; font-weight:300; letter-spacing:0.12em; text-transform:uppercase; color:#a8a29e; padding-top:5px;">
                  <%= guest.rsvp.meal_choice %>
                </div>
              <% end %>
            </td>
            <td align="right" style="vertical-align:top; text-align:right;">
              <div class="sans" style="font-family:'Montserrat',Helvetica,Arial,sans-serif; font-size:11px; font-weight:500; letter-spacing:0.14em; text-transform:uppercase; color:<%= label_color %>;">
                <%= label %>
              </div>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  <% end %>
</table>

<p class="sans" style="margin:28px 0 32px; text-align:center; font-family:'Montserrat',Helvetica,Arial,sans-serif; font-size:15px; font-weight:300; line-height:1.9; color:#57534e;">
  Need to make a change? You may update your response any time before the big day.
</p>

<%= render "mailer_shared/button", url: @rsvp_url, label: "Update RSVP" %>

<p class="mono" style="margin:32px 0 0; text-align:center; font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:18px; font-weight:400; color:#78716c;">
  We can&rsquo;t wait to celebrate with you.
</p>
