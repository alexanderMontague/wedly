<nav class="wedding-nav" data-controller="nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24">
      <%= link_to root_path, class: "flex items-center no-underline" do %>
        <span class="text-3xl font-display text-stone-800">
          <%= current_wedding&.title || "Wedding" %>
        </span>
      <% end %>

      <%# Desktop links %>
      <div class="hidden md:flex gap-8">
        <%= link_to "Home", root_path,
            class: class_names("wedding-nav-link", { active: current_page?(root_path) }) %>
        <%= link_to "Gallery", public_gallery_path,
            class: class_names("wedding-nav-link", { active: current_page?(public_gallery_path) }) %>
        <%= link_to "Wedding Party", public_wedding_party_path,
            class: class_names("wedding-nav-link", { active: current_page?(public_wedding_party_path) }) %>
        <%= link_to "FAQ", public_faq_path,
            class: class_names("wedding-nav-link", { active: current_page?(public_faq_path) }) %>
        <%= link_to "Save the Date", public_save_the_date_path,
            class: class_names("wedding-nav-link", { active: current_page?(public_save_the_date_path) }) %>
        <% if current_wedding.rsvp_visible? %>
          <%= link_to "RSVP", public_rsvp_lookup_path,
              class: class_names("wedding-nav-link", { active: request.path.start_with?('/rsvp') }) %>
        <% end %>
      </div>

      <%# Mobile hamburger button %>
      <button class="md:hidden p-2 -mr-2 text-stone-600 hover:text-stone-800 transition-colors"
              data-action="nav#toggle"
              aria-label="Toggle navigation">
        <svg data-nav-target="openIcon" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
        <svg data-nav-target="closeIcon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <%# Mobile menu %>
  <div class="md:hidden hidden border-t border-stone-200/50" data-nav-target="menu" data-action="click->nav#close">
    <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col gap-6">
      <%= link_to "Home", root_path,
          class: class_names("wedding-nav-link self-start", { active: current_page?(root_path) }) %>
      <%= link_to "Gallery", public_gallery_path,
          class: class_names("wedding-nav-link self-start", { active: current_page?(public_gallery_path) }) %>
      <%= link_to "Wedding Party", public_wedding_party_path,
          class: class_names("wedding-nav-link self-start", { active: current_page?(public_wedding_party_path) }) %>
      <%= link_to "FAQ", public_faq_path,
          class: class_names("wedding-nav-link self-start", { active: current_page?(public_faq_path) }) %>
      <%= link_to "Save the Date", public_save_the_date_path,
          class: class_names("wedding-nav-link self-start", { active: current_page?(public_save_the_date_path) }) %>
      <% if current_wedding.rsvp_visible? %>
        <%= link_to "RSVP", public_rsvp_lookup_path,
            class: class_names("wedding-nav-link self-start", { active: request.path.start_with?('/rsvp') }) %>
      <% end %>
    </div>
  </div>
</nav>
