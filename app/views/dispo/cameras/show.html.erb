<main
  class="dispo-stage"
  data-controller="dispo-camera"
  data-dispo-camera-upload-url-value="<%= dispo_upload_path %>"
  data-dispo-camera-closes-at-value="<%= (current_wedding.dispo_camera_closes_at.to_f * 1000).round %>"
  data-dispo-camera-forced-locked-value="<%= !current_wedding.dispo_accepting_photos? %>"
>
  <%= turbo_stream_from dispo_total_photos_stream %>

  <div class="dispo-camera-shell">
    <span class="dispo-rivet dispo-rivet--tl"></span>
    <span class="dispo-rivet dispo-rivet--tr"></span>
    <span class="dispo-rivet dispo-rivet--bl"></span>
    <span class="dispo-rivet dispo-rivet--br"></span>

    <header class="dispo-camera-top">
      <div class="dispo-brand-wrap">
        <span class="dispo-burst">✺</span>
        <div class="dispo-brand-text">
          <p class="dispo-camera-brand"><%= current_wedding.last_name %> Dispo</p>
          <p class="dispo-camera-meta">400 ISO · 27 EXP · <%= format_date_short(current_wedding.date) %></p>
        </div>
      </div>
      <div class="dispo-top-right">
        <span class="dispo-led"></span>
        <div class="dispo-film-counter">
          <span class="dispo-film-counter__label">Photos</span>
          <span class="dispo-film-counter__value">
            <%= render "total_photos", total_photos: @total_photos %>
          </span>
        </div>
      </div>
    </header>

    <div class="dispo-viewfinder-section">
      <div class="dispo-viewfinder-frame">
        <video class="dispo-viewfinder" data-dispo-camera-target="video" autoplay playsinline muted></video>
        <canvas class="hidden" data-dispo-camera-target="canvas"></canvas>
        <div class="dispo-flash-pop hidden" data-dispo-camera-target="flashPop"></div>

        <div class="dispo-permission-gate" data-dispo-camera-target="permissionGate">
          <span class="dispo-permission-icon">✺</span>
          <p class="dispo-permission-title">Enable Camera Access</p>
          <p class="dispo-permission-copy">Tap to allow camera permissions and start capturing disposable memories.</p>
          <button type="button" class="dispo-permission-btn" data-action="dispo-camera#requestCameraAccess" data-dispo-camera-target="permissionButton">
            Enable Camera
          </button>
        </div>

        <div class="dispo-locked-gate hidden" data-dispo-camera-target="lockedGate">
          <span class="dispo-permission-icon dispo-locked-icon">🎞</span>
          <p class="dispo-permission-title">Film's Up</p>
          <p class="dispo-permission-copy">The disposable camera closed at the end of the celebration. Thank you for capturing these memories!</p>
        </div>

        <div class="dispo-viewfinder-overlay">
          <span></span><span></span><span></span><span></span>
        </div>
      </div>
    </div>

    <footer class="dispo-controls">
      <div class="dispo-controls-pills">
        <button type="button" class="dispo-flash-btn" data-action="dispo-camera#toggleFlash" data-dispo-camera-target="flashButton">
          Flash: Off
        </button>
        <button type="button" class="dispo-flip-btn hidden" data-action="dispo-camera#flipCamera" data-dispo-camera-target="flipButton">
          Flip
        </button>
      </div>
      <p class="dispo-status" data-dispo-camera-target="status">Enable camera to begin.</p>
      <div class="dispo-shutter-wrap">
        <button type="button" class="dispo-shutter-btn" data-action="dispo-camera#takePhoto" data-dispo-camera-target="shutterButton">
          Capture
        </button>
      </div>
    </footer>
  </div>
</main>
