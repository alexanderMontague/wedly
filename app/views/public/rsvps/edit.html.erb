<%= render layout: "public/shared/full_width_invitation_video",
      locals: {
        extra_controllers: "rsvp-form",
        data: { rsvp_form: { guest_ids_value: @guests.map(&:id).to_json } }
      } do %>
  <div class="invitation-video-content hidden min-h-screen px-4 py-10 md:py-20"
       data-invitation-video-target="content">
    <%= render "public/shared/invitation_frame" do %>
      <%= render "public/shared/invitation_hero",
          eyebrow: "RSVP",
          title: current_wedding.title %>

      <%= render "public/shared/flash_messages" %>

      <div class="space-y-10 text-center">
        <div class="space-y-4">
          <p class="invitation-eyebrow">You're Invited</p>
          <h2 class="invitation-party-name"><%= @household.display_name %></h2>
        </div>

        <div class="space-y-4">
          <% if current_wedding.date %>
            <p class="font-display text-2xl font-light text-stone-800 md:text-3xl">
              <%= format_date_elegant(current_wedding.date) %>
            </p>
          <% end %>
          <% if current_wedding.venue %>
            <div class="space-y-1">
              <p class="font-light text-stone-600"><%= current_wedding.venue['name'] %></p>
              <p class="text-sm font-light text-stone-500">
                <%= full_venue_name(current_wedding.venue) %>
              </p>
            </div>
          <% end %>
        </div>

        <div>
          <button type="button"
                  data-action="click->invitation-video#showForm"
                  class="btn-wedding-primary">
            Respond Now
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <div class="hidden" data-invitation-video-target="form">
    <div class="rsvp-form-card mx-auto max-w-2xl px-4 pb-20 animate-fade-in-up">
      <div class="mb-12">
        <h2 class="mb-2 font-display text-3xl font-light text-stone-800">
          <%= @household.display_name %>
        </h2>
        <p class="font-light text-stone-500">
          Please respond for each guest in your party
        </p>
        <% if current_wedding.rsvp_deadline %>
          <p class="mt-2 text-sm font-light text-stone-400">
            Kindly respond by <%= format_date(current_wedding.rsvp_deadline) %>
          </p>
        <% end %>
      </div>

      <%= form_with url: public_rsvp_path(@guest.invite_code), method: :patch, data: { turbo: false } do |f| %>
        <% @guests.each_with_index do |guest, index| %>
          <%= render "public/rsvps/guest_fields", guest: guest, index: index %>
        <% end %>

        <div class="pt-12">
          <%= f.submit "Submit Response", class: "rsvp-submit" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
