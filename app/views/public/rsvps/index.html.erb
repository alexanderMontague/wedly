<div class="min-h-screen bg-gradient-to-b from-stone-50 via-amber-50/30 to-stone-100 px-4 py-10 md:py-20">
  <%= render "public/shared/invitation_frame" do %>
    <%= render "public/shared/invitation_hero",
        eyebrow: "RSVP",
        title: current_wedding.title %>

    <p class="invitation-lead mb-10 text-center">
      Search for your name to find your invitation
    </p>

    <div class="animate-fade-in-up"
         style="animation-delay: 0.2s;"
         data-controller="guest-search"
         data-guest-search-url-value="<%= public_rsvp_search_path %>">
      <div class="mb-8">
        <label class="rsvp-label">Your Name</label>
        <div class="relative">
          <input type="text"
                 data-guest-search-target="input"
                 data-action="input->guest-search#search"
                 placeholder="Enter your first or last name"
                 autocomplete="off"
                 class="w-full border-b-2 border-stone-300 bg-transparent px-0 py-4 font-display text-xl text-stone-800 outline-none transition-colors focus:border-stone-800" />
          <div class="absolute right-0 top-1/2 -translate-y-1/2">
            <%= render "public/shared/icon", name: "search" %>
          </div>
        </div>
      </div>

      <div data-guest-search-target="searching" class="hidden py-8 text-center">
        <p class="text-sm font-light text-stone-500">Searching...</p>
      </div>

      <div data-guest-search-target="results" class="hidden">
        <p class="rsvp-label mb-4">Select your name</p>
        <div class="border border-stone-200">
        </div>
      </div>

      <div data-guest-search-target="noResults" class="hidden py-8 text-center">
        <div class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full border border-stone-300">
          <%= render "public/shared/icon", name: "sad" %>
        </div>
        <p class="mb-2 font-display text-lg text-stone-800">No guests found</p>
        <p class="text-sm font-light text-stone-500">
          Please check the spelling or try a different name
        </p>
      </div>

      <div class="mt-8 border-t border-primary/10 pb-24 pt-8 sm:pb-28">
        <p class="text-center text-sm font-light text-stone-400">
          If you received an invitation link, you can use that to go directly to your RSVP
        </p>
      </div>
    </div>
  <% end %>
</div>
