<div class="relative min-h-screen bg-gradient-to-b from-stone-50 via-amber-50/30 to-stone-100"
     data-controller="invitation-video">
  <%= render "public/shared/invitation_video_stage",
        video_src: asset_path("britt&alex-wedding-invite.mp4") %>

  <div class="invitation-video-content hidden min-h-screen px-4 py-20"
       data-invitation-video-target="content">
    <div class="mx-auto max-w-2xl">
      <div class="animate-fade-in-up mb-16 text-center">
        <%= render "public/shared/divider" %>
        <div class="mb-8"></div>
        <h1 class="mb-6 font-display text-6xl font-light tracking-wide text-stone-800">
          Save the Date
        </h1>
        <p class="mb-4 text-lg font-light text-stone-600">
          <%= current_wedding.title %>
        </p>
        <p class="text-sm font-light tracking-wider text-stone-500">
          We hope you can join us
        </p>
      </div>

      <%= render "public/save_the_dates/envelope" %>
    </div>
  </div>
</div>
