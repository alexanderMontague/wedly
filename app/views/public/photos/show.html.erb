<div class="min-h-screen" data-controller="scroll-animate">
  <section class="py-32 px-4 bg-gradient-to-b from-stone-50 via-amber-50/30 to-stone-100">
    <div class="max-w-3xl mx-auto text-center animate-fade-in-up">
      <%= render "public/shared/divider" %>
      <div class="mb-8"></div>
      <h1 class="text-6xl mb-6 tracking-wide font-display font-light text-stone-800">
        <%= current_wedding.photos_page["title"] %>
      </h1>
      <p class="text-base tracking-wider text-stone-500 font-light">
        <%= current_wedding.photos_page["subtitle"] %>
      </p>
    </div>
  </section>

  <% current_wedding.photos_page["sections"]&.each_with_index do |section, section_index| %>
    <section class="py-24 px-4 <%= section_index.odd? ? 'bg-stone-100/50 border-y border-stone-200' : '' %>">
      <div class="max-w-7xl mx-auto">
        <%= render "public/shared/divider" %>
        <div class="mb-12"></div>
        <%= render "public/shared/section_title", title: section["title"], centered: true %>
        <div class="mb-16"></div>
        <div class="grid md:grid-cols-3 gap-6">
          <% section["images"]&.each_with_index do |image, index| %>
            <% delay_class = ["", "animation-delay-200", "animation-delay-400"][index % 3] %>
            <div class="gallery-item animate-on-scroll <%= delay_class %>" data-scroll-animate-target="item">
              <%= image_tag image["url"], alt: image["alt"], loading: "lazy" %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <footer class="wedding-footer">
    <p class="text-xs tracking-[0.2em] uppercase mb-2"><%= current_wedding.title %></p>
    <% if current_wedding.date %>
      <p class="text-xs font-light"><%= format_date_short(current_wedding.date) %></p>
    <% end %>
  </footer>
</div>
