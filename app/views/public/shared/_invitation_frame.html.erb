<div class="invitation-frame-shell mx-auto max-w-2xl">
  <div class="invitation-frame relative z-10">
    <div class="invitation-frame-botanical invitation-frame-botanical--top-left">
      <%= render "public/shared/botanical_accent", placement: "top-left" %>
    </div>
    <div class="invitation-frame-botanical invitation-frame-botanical--bottom-right">
      <%= render "public/shared/botanical_accent", placement: "bottom-right" %>
    </div>

    <div class="invitation-frame-content relative z-10">
      <%= yield %>
    </div>
  </div>
</div>
