<%
  divider_height = local_assigns.fetch(:divider_height, 16)
  show_ornament = local_assigns.fetch(:show_ornament, true)
  header_class = local_assigns.fetch(:header_class, "mb-10")
%>
<header class="invitation-hero animate-fade-in-up text-center <%= header_class %>">
  <div class="mb-8">
    <%= render "public/shared/divider", height: divider_height %>
  </div>
  <% if local_assigns[:eyebrow].present? %>
    <div class="invitation-eyebrow-row">
      <p class="invitation-eyebrow mb-0"><%= eyebrow %></p>
    </div>
  <% end %>
  <h1 class="invitation-title"><%= title %></h1>
  <% if local_assigns[:subtitle].present? %>
    <p class="invitation-subtitle"><%= subtitle %></p>
  <% end %>
  <% if show_ornament %>
    <div class="space-y-3">
      <%= render "public/shared/botanical_ornament" %>
    </div>
  <% end %>
</header>
