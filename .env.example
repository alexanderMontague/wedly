SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

APP_HOST=localhost:3003

# Disposable camera storage backend. Defaults to local disk in development/test and
# the S3-compatible bucket in production. Override with "local" or "s3".
# DISPOSABLE_CAMERA_STORAGE=local

# Disposable camera object storage (Cloudflare R2, S3-compatible API) — used when the
# backend is "s3" (production by default).
BUCKET_NAME=wedly
R2_ACCOUNT_ID=your-cloudflare-account-id
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Region must be "auto" for R2
AWS_REGION=auto

# Optional: override the S3 API endpoint (defaults to https://$R2_ACCOUNT_ID.r2.cloudflarestorage.com)
# AWS_ENDPOINT_URL_S3=
